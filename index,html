<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>What Is A Side? | The Magazine</title>
  <meta name="description" content="The home of Side identity. Stories, culture, and community for gay and bi men who are Sides and Short Stops." />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #080810;
      --bg2: #0f0f1c;
      --bg3: #131320;
      --gold: #c8a84b;
      --gold2: #e0c875;
      --cream: #ede6d6;
      --muted: #5a5a72;
      --white: #ffffff;
      --rule: rgba(200,168,75,0.15);
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--cream);
      font-family: 'Inter', sans-serif;
      font-weight: 300;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    img { display: block; width: 100%; object-fit: cover; }
    a { color: inherit; text-decoration: none; }

    /* TOP BANNER */
    .top-banner {
      background: var(--gold);
      color: var(--bg);
      text-align: center;
      padding: 0.65rem 2rem;
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      font-weight: 500;
    }

    .top-banner a {
      color: var(--bg);
      font-weight: 600;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    /* NAV */
    nav {
      position: sticky; top: 0; z-index: 200;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      padding: 0 2rem;
      height: 58px;
      background: rgba(8,8,16,0.94);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--rule);
    }

    .nav-left {
      display: flex; gap: 1.6rem;
      font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase;
    }

    .nav-left a { color: var(--cream); opacity: 0.55; transition: opacity 0.2s; }
    .nav-left a:hover { opacity: 1; }

    .nav-center {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.25rem; font-weight: 700;
      color: var(--gold); letter-spacing: 0.05em;
      text-align: center; white-space: nowrap;
    }

    .nav-right { display: flex; justify-content: flex-end; }

    .nav-cta {
      font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase;
      background: var(--gold); color: var(--bg);
      padding: 0.45rem 1.1rem; border-radius: 1px;
      font-weight: 600; transition: background 0.2s;
    }

    .nav-cta:hover { background: var(--gold2); }

    /* HERO */
    .hero {
      position: relative;
      height: 90vh; min-height: 560px;
      display: flex; flex-direction: column;
      justify-content: flex-end;
      overflow: hidden;
    }

    .hero-img {
      position: absolute; inset: 0;
      background-image: url('https://images.unsplash.com/photo-1529333166437-7750a6dd5a70?w=1400&q=80');
      background-size: cover; background-position: center top;
    }

    .hero-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to bottom, rgba(8,8,16,0.1) 0%, rgba(8,8,16,0.5) 50%, rgba(8,8,16,0.97) 100%);
    }

    .hero-content {
      position: relative; z-index: 2;
      max-width: 860px; margin: 0 auto;
      padding: 0 2rem 4rem;
      width: 100%;
    }

    .hero-tag {
      display: inline-block;
      font-size: 0.68rem; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--gold); border: 1px solid rgba(200,168,75,0.5);
      padding: 0.25rem 0.8rem; border-radius: 1px;
      margin-bottom: 1.25rem;
    }

    .hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3rem, 8vw, 6rem);
      font-weight: 700; line-height: 1.0;
      color: var(--white); margin-bottom: 1.25rem;
      max-width: 700px;
    }

    .hero h1 em { font-style: italic; color: var(--gold); }

    .hero-deck {
      font-size: 1.05rem; color: var(--cream);
      opacity: 0.72; max-width: 480px;
      line-height: 1.65;
    }

    /* LAYOUT */
    .wrap { max-width: 860px; margin: 0 auto; padding: 0 2rem; }
    .rule { border: none; border-top: 1px solid var(--rule); margin: 0; }

    .section-label {
      font-size: 0.68rem; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--gold);
      padding: 2.5rem 0 1.5rem;
      display: flex; align-items: center; gap: 1rem;
    }

    .section-label::after {
      content: ''; flex: 1;
      height: 1px; background: var(--rule);
    }

    /* IDENTITY */
    .identity {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      padding-bottom: 4rem;
    }

    @media (max-width: 620px) { .identity { grid-template-columns: 1fr; } }

    .id-card {
      position: relative; overflow: hidden;
      border-radius: 2px; aspect-ratio: 3/4;
    }

    .id-card img {
      height: 100%; object-fit: cover;
      transition: transform 0.6s ease;
    }

    .id-card:hover img { transform: scale(1.04); }

    .id-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(8,8,16,0.95) 0%, rgba(8,8,16,0.2) 60%, transparent 100%);
    }

    .id-text {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 1.75rem;
    }

    .id-label {
      font-size: 0.65rem; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--gold);
      margin-bottom: 0.5rem;
    }

    .id-text h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem; font-weight: 700;
      color: var(--white); line-height: 1.1;
      margin-bottom: 0.75rem;
    }

    .id-text p {
      font-size: 0.88rem; color: var(--cream);
      opacity: 0.75; line-height: 1.65;
    }

    /* SF STRIP */
    .sf-strip {
      background: var(--bg2);
      border-top: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
      padding: 2.5rem 2rem;
      text-align: center;
    }

    .sf-strip p {
      font-size: 0.9rem; color: var(--cream);
      opacity: 0.65; margin-bottom: 1rem;
    }

    .sf-strip h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.6rem; font-weight: 700;
      color: var(--white); margin-bottom: 0.5rem;
    }

    .sf-btn {
      display: inline-block;
      background: var(--gold); color: var(--bg);
      padding: 0.75rem 2rem; border-radius: 1px;
      font-size: 0.78rem; letter-spacing: 0.12em;
      text-transform: uppercase; font-weight: 600;
      transition: background 0.2s; margin-top: 1rem;
    }

    .sf-btn:hover { background: var(--gold2); }

    /* BLOG */
    .blog-featured {
      display: grid;
      grid-template-columns: 1.6fr 1fr;
      gap: 1.5rem;
      padding-bottom: 1.5rem;
    }

    @media (max-width: 660px) { .blog-featured { grid-template-columns: 1fr; } }

    .blog-secondary {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      padding-bottom: 4rem;
    }

    @media (max-width: 660px) { .blog-secondary { grid-template-columns: 1fr; } }

    .blog-card { display: flex; flex-direction: column; }

    .blog-img { overflow: hidden; border-radius: 2px; aspect-ratio: 16/10; }
    .blog-img.tall { aspect-ratio: 4/5; }
    .blog-img img { height: 100%; transition: transform 0.5s ease; }
    .blog-card:hover .blog-img img { transform: scale(1.04); }

    .blog-body { padding: 1rem 0 0; flex: 1; }

    .blog-cat {
      font-size: 0.64rem; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--gold);
      margin-bottom: 0.5rem;
    }

    .blog-card h3 {
      font-family: 'Cormorant Garamond', serif;
      color: var(--white); line-height: 1.25;
      margin-bottom: 0.6rem;
    }

    .blog-featured .blog-card h3 { font-size: 1.7rem; font-weight: 700; }
    .blog-secondary .blog-card h3 { font-size: 1.15rem; font-weight: 600; }

    .blog-card p { font-size: 0.86rem; color: var(--cream); opacity: 0.6; line-height: 1.6; }
    .blog-date { font-size: 0.7rem; color: var(--muted); margin-top: 0.75rem; }

    /* MERCH */
    .merch-section {
      background: var(--bg2);
      border-top: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
      padding: 4rem 0;
    }

    .merch-header {
      display: flex; justify-content: space-between;
      align-items: baseline; margin-bottom: 2rem;
    }

    .merch-header h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem; font-weight: 700; color: var(--white);
    }

    .merch-header span {
      font-size: 0.72rem; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--muted);
    }

    .merch-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    @media (max-width: 620px) { .merch-grid { grid-template-columns: 1fr; } }

    .merch-card { background: var(--bg3); border-radius: 2px; overflow: hidden; }

    .merch-thumb {
      aspect-ratio: 1;
      background: linear-gradient(135deg, #1a1a30, #0d0d20);
      display: flex; align-items: center; justify-content: center;
      font-size: 4rem;
    }

    .merch-info { padding: 1.25rem; }

    .merch-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem; font-weight: 700;
      color: var(--white); margin-bottom: 0.5rem;
    }

    .coming-soon {
      font-size: 0.68rem; letter-spacing: 0.15em;
      text-transform: uppercase; color: var(--gold);
      border: 1px solid rgba(200,168,75,0.35);
      padding: 0.22rem 0.65rem; border-radius: 1px;
      display: inline-block;
    }

    /* FOOTER */
    footer {
      border-top: 1px solid var(--rule);
      padding: 2.5rem 2rem;
      text-align: center;
      font-size: 0.75rem; color: var(--muted);
    }

    footer a { color: var(--gold); }
  </style>
</head>
